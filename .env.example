# Anomaly Detection Dashboard - Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control

# --- App Settings ---
# Title displayed in the browser tab
APP_TITLE="Anomaly Detection Dashboard"

# Default contamination rate for Isolation Forest (0.01 to 0.5)
DEFAULT_CONTAMINATION=0.05

# Default Z-score threshold (standard deviations)
DEFAULT_ZSCORE_THRESHOLD=3.0

# Default rolling window size for rolling statistics (in data points)
DEFAULT_WINDOW_SIZE=20

# --- Logging ---
# Set to DEBUG for verbose output, INFO for production
LOG_LEVEL=INFO

# --- Data ---
# Maximum file upload size in MB (Streamlit default is 200)
MAX_UPLOAD_SIZE_MB=50
